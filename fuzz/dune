(executable
 (name fuzz_wire)
 (modules fuzz_wire)
 (libraries wire crowbar))

; Quick check with Crowbar (no AFL instrumentation)

(rule
 (alias fuzz)
 (deps fuzz_wire.exe)
 (action
  (run %{exe:fuzz_wire.exe})))

; AFL-instrumented build target (use with --profile=afl)

(rule
 (alias fuzz-afl)
 (deps
  (source_tree input)
  fuzz_wire.exe)
 (action
  (echo "AFL fuzzer built: %{exe:fuzz_wire.exe}\n")))

(executable
 (name fuzz_wire)
 (modules fuzz_wire)
 (libraries wire crowbar))

(executable
 (name gen_corpus)
 (modules gen_corpus))

(rule
 (alias runtest)
 (deps fuzz_wire.exe)
 (action
  (run %{exe:fuzz_wire.exe})))

(rule
 (alias fuzz)
 (enabled_if
  (= %{profile} afl))
 (deps
  (source_tree corpus)
  fuzz_wire.exe
  gen_corpus.exe)
 (action
  (echo "AFL fuzzer built: %{exe:fuzz_wire.exe}\n")))

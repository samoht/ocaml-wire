; ── Pure C scenario baselines (always build) ──

(library
 (name c_scenarios)
 (modules c_scenarios)
 (foreign_stubs
  (language c)
  (names c_scenarios)))

; ── Realistic scenario benchmarks (always build) ──

(executable
 (name bench_routing)
 (modules bench_routing)
 (libraries space wire c_scenarios unix fmt))

(executable
 (name bench_gateway)
 (modules bench_gateway)
 (libraries space wire c_scenarios unix fmt))

(executable
 (name bench_clcw)
 (modules bench_clcw)
 (libraries space wire c_scenarios unix fmt))

; Memtrace allocation profiling (always builds)

(executable
 (name memtrace)
 (modules memtrace)
 (libraries demo space wire memtrace))

; ── EverParse benchmark infrastructure (BUILD_EVERPARSE=1 only) ──

; Step 1: Generator — produces .3d files, runs EverParse, generates C/ML stubs

(executable
 (name gen_stubs)
 (modules gen_stubs)
 (enabled_if
  (= %{env:BUILD_EVERPARSE=} "1"))
 (libraries demo space net wire wire.c unix))

; Step 2: Run the generator to produce all artifacts

(rule
 (enabled_if
  (= %{env:BUILD_EVERPARSE=} "1"))
 (targets
  (dir schemas)
  c_stubs.c
  c_stubs.ml)
 (deps gen_stubs.exe)
 (action
  (run ./gen_stubs.exe schemas)))

; Step 3: C stubs library (EverParse validation + timed loops + OCaml externals)

(library
 (name c_stubs)
 (modules c_stubs)
 (enabled_if
  (= %{env:BUILD_EVERPARSE=} "1"))
 (foreign_stubs
  (language c)
  (names c_stubs)
  (flags :standard -I schemas)))

; ── Shared benchmark framework ──

(library
 (name bench_lib)
 (modules bench_lib)
 (libraries unix fmt))

rules:
  # TCP has 9 flag bits — positional constructor imposed by Codec.view
  - files: examples/net/net.ml
    exclude: [E350]

  # Linter contradiction: wants both lowercase and matching uInt filename
  - files: test/test_uInt32.ml
    exclude: [E617]
  - files: test/test_uInt63.ml
    exclude: [E617]
